# Azure OpenAI - LLM
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL=<your-gpt-deployment-name>

# Azure OpenAI - Embedding
# Can be the same endpoint as above if models are on the same resource
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION_EMBEDDING=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_MODEL=<your-embedding-deployment-name>
